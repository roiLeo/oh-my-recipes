{
  "name": "oh-my-recipes",
  "description": "A Nuxt starter template with TypeScript, ESLint, Prettier, Husky, lint-staged, Nuxt UI, and i18n configured and ready to use.",
  "repository": {
    "type": "git",
    "url": "https://github.com/roiLeo/oh-my-recipes.git"
  },
  "bugs": {
    "url": "https://github.com/roiLeo/oh-my-recipes/issues"
  },
  "scripts": {
    "dev": "nuxi dev",
    "build": "nuxi build",
    "start": "nuxi start",
    "lint": "eslint --ignore-path .gitignore --ext .js,.ts,.vue .",
    "lint:quiet": "eslint --quiet --ignore-path .gitignore --ext .js,.ts,.vue .",
    "lint:fix": "eslint --fix --quiet --ignore-path .gitignore --ext .js,.ts,.vue ."
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@nuxt/devtools": "3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@nuxt/content": "3.13.0",
    "@nuxt/ui": "4.7.0",
    "@nuxtjs/i18n": "^10.3.0",
    "nuxt": "^4.4.2",
    "sqlite3": "^6.0.1"
  },
  "packageManager": "pnpm@9.15.7+sha512.ed98f9c748442673c46964b70345bd2282c9b305e8eae539b34ab31d6ef24ef8dd59d8b55f27466f705500b009d9c113471cf87e544f3d5036b297330c26e996"
}
